{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "ski99-game",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "index.html"
      }
    }
  },
  "media": {
    "dir": "assets"
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Create Ski99 Post",
        "description": "Create the initial Ski99 game post in this subreddit",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/on-app-install"
      }
    ]
  },
  "triggers": {
    "onAppInstall": "/internal/on-app-install"
  },
  "permissions": {
    "reddit": {
      "asUser": [
        "SUBMIT_POST",
        "SUBMIT_COMMENT",
        "SUBSCRIBE_TO_SUBREDDIT"
      ]
    }
  },
  "dev": {
    "subreddit": "ski99_game_dev"
  }
}
<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:VisualElement style="flex-grow: 1; position: absolute; top: auto; left: auto; right: 0; bottom: 0; background-color: rgba(255, 255, 255, 0.57); -unity-font-style: bold; width: 329px;">
        <ui:IntegerField label="Score: v2" value="99" name="ScoreField" />
        <ui:IntegerField label="Distance" value="1500" name="DistanceField" />
        <ui:Toggle label="As User" value="true" name="AsUserToggle" />
        <ui:Button text="Submit" name="SubmitButton" />
    </ui:VisualElement>
    <ui:Label text="LogLabel" name="LogLabel" style="bottom: 0; left: 0; position: absolute; width: 190px; height: 170px; background-color: rgba(12, 12, 12, 0.76); color: rgb(255, 255, 255); white-space: pre-wrap; font-size: 12px;" />
</ui:UXML>
